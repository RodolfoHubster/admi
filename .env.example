# =============================
# Backend (PHP + Gemini)
# =============================
GEMINI_API_KEY=replace-with-real-key
GEMINI_MODEL=gemini-1.5-flash
ALLOWED_ORIGINS=https://rodolfohubster.github.io
DEFAULT_ALLOWED_ORIGIN=

# =============================
# Database
# =============================
DB_HOST=localhost
DB_NAME=perfume_db
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# =============================
# Frontend runtime config (Cloud Run container)
# Se inyecta automáticamente a assets/js/runtime-config.js
# =============================
ASISTENTE_API_ENDPOINT=
ASISTENTE_API_HEALTH_ENDPOINT=
ASISTENTE_API_KEY=
ASISTENTE_API_KEY_HEADER=X-API-Key
ASISTENTE_API_BEARER_TOKEN=
ASISTENTE_API_AUTH_HEADER=Authorization
ASISTENTE_API_AUTH_SCHEME=Bearer

EXCHANGE_API_ENDPOINT=https://api.exchangerate-api.com/v4/latest/USD
EXCHANGE_API_HEALTH_ENDPOINT=
EXCHANGE_API_KEY=
EXCHANGE_API_KEY_HEADER=X-API-Key
EXCHANGE_API_BEARER_TOKEN=
EXCHANGE_API_AUTH_HEADER=
EXCHANGE_API_AUTH_SCHEME=Bearer
